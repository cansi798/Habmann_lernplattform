# Default: treat as text, normalize to LF in repo
* text=auto eol=lf

# Explicit text formats
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.tex   text eol=lf
*.svg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.mp4   binary
*.zip   binary
*.xlsx  binary
*.docx  binary
